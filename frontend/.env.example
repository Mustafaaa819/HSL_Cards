# Copy this to `.env.development.local` (not `.env.local` — that file's
# values leak into production builds too, which is not what we want here).
# Only needed for local dev, where frontend (Vite) and backend (uvicorn)
# run as separate servers. In production the frontend is served from the
# same origin as the backend, so this is auto-derived and unused.
VITE_WS_URL=ws://localhost:8000/ws/test
